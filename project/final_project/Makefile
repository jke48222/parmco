# ==============================================================================
# PARMCO BLE Server — Makefile
# ==============================================================================
#
# Project:  PARMCO (Phone APP RP4 Motor Control)
# Course:   ECSE 4235 — Embedded Systems, Spring 2026
# Authors:  Justin Moreno and Jalen Edusei
# Date:     March 25, 2026
#
# AI Attribution:
#   This Makefile was AI-Generated by Claude Opus 4.6 (Anthropic).
#
# Usage:
#   make            — compile the BLE server
#   make clean      — remove the compiled binary
#   make install    — install the systemd service for auto-start on boot
#   make uninstall  — disable and remove the systemd service
#   make run        — compile and run immediately (requires sudo)
#
# Dependencies (install with apt):
#   sudo apt install libglib2.0-dev bluetooth bluez libbluetooth-dev
#
# ==============================================================================

CC      = gcc

# CFLAGS explanation:
#   -Wall -Wextra   — enable comprehensive compiler warnings
#   -O2             — optimize for speed (suitable for embedded deployment)
#   $(shell ...)    — pkg-config queries the system for the correct include
#                     paths and compiler flags for GLib 2.0 and GIO 2.0.
#                     On a typical RP4 this expands to something like:
#                       -I/usr/include/glib-2.0 -I/usr/lib/aarch64-linux-gnu/glib-2.0/include
CFLAGS  = -Wall -Wextra -O2 $(shell pkg-config --cflags glib-2.0 gio-2.0)

# LDFLAGS explanation:
#   pkg-config --libs queries the linker flags for the GLib/GIO shared
#   libraries. This typically expands to:
#     -lglib-2.0 -lgio-2.0 -lgobject-2.0
#   CP3 additions:
#     -lpigpio -lrt -lpthread — pigpio drives the L293D PWM and IR
#     edge-detect callbacks from inside ble_server itself (see the
#     motor_hw_* block in ble_server.c). Previously the motor daemon
#     was a separate process and the BLE server never touched GPIO.
LDFLAGS = $(shell pkg-config --libs glib-2.0 gio-2.0) -lpigpio -lrt -lpthread

# Source and target
# ble_server.c lives in this folder (Project_CP3/ble/ble_server.c)
SRC     = ble_server.c
ASM_OBJ = ../motor/gpio_asm.o
TARGET  = ble_server

# Systemd service name (CP3 F5: must match firmware_spec.md)
SERVICE = parmco-ble.service

# ==============================================================================
# Build targets
# ==============================================================================

all: $(TARGET)

$(TARGET): $(SRC) $(ASM_OBJ)
	$(CC) $(CFLAGS) -o $(TARGET) $(SRC) $(ASM_OBJ) $(LDFLAGS)
	@echo ""
	@echo "Build complete: ./$(TARGET)"
	@echo "Run with: sudo ./$(TARGET)"

$(ASM_OBJ):
	$(MAKE) -C ../motor gpio_asm.o

clean:
	rm -f $(TARGET)
	@echo "Cleaned."

# ==============================================================================
# Systemd service management
# ==============================================================================

install: $(TARGET)
	@echo "Installing PARMCO BLE server as a systemd service..."
	sudo cp $(TARGET) /usr/local/bin/$(TARGET)
	sudo cp $(SERVICE) /etc/systemd/system/$(SERVICE)
	sudo systemctl daemon-reload
	sudo systemctl enable $(SERVICE)
	sudo systemctl start $(SERVICE)
	@echo ""
	@echo "Service installed and started."
	@echo "Check status: sudo systemctl status $(SERVICE)"
	@echo "View logs:    sudo journalctl -u $(SERVICE) -f"

uninstall:
	@echo "Removing PARMCO BLE service..."
	-sudo systemctl stop $(SERVICE)
	-sudo systemctl disable $(SERVICE)
	-sudo rm -f /etc/systemd/system/$(SERVICE)
	-sudo rm -f /usr/local/bin/$(TARGET)
	sudo systemctl daemon-reload
	@echo "Service removed."

run: $(TARGET)
	sudo ./$(TARGET)

.PHONY: all clean install uninstall run

